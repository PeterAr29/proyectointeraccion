# ==========================================================================
# BiblioTEC — variables de entorno (EJEMPLO)
# Copia este archivo a .env.local y rellena con valores reales.
# NUNCA comitees .env.local ni valores reales. .env* está en .gitignore.
# ==========================================================================

# App
NODE_ENV=development

# --- Supabase (públicas: se exponen al navegador) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-dummy

# --- Supabase (SECRETA: SOLO servidor, jamás en "use client") ---
# Se usa únicamente en Server Actions / Route Handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-dummy

# --- URL pública de la app (para redirects de auth, CORS) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- (Opcional) Supabase local CLI: connection string de la BD local ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
